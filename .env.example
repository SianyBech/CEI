# Porta HTTP do servidor
PORT=3000

# Host: use 0.0.0.0 para aceitar conexões de qualquer máquina na rede
HOST=0.0.0.0

# Caminho absoluto da pasta de armazenamento compartilhada
# Exemplo no Windows: \\SERVIDOR\Compartilhamento\cerne-storage
# Exemplo local: C:\\Users\\CEI\\.gemini\\antigravity\\scratch\\cerne-evidencias-mvp\\storage
# Se não informado, usa storage/ dentro do projeto.
STORAGE_PATH=

# Caminho absoluto para o banco de dados SQLite
# Se não informado, usa storage/db/evidences.db
DB_PATH=

# Se estiver usando Supabase/Postgres, defina os dados abaixo
# ou forneça DATABASE_URL direto.
# DB_TYPE=postgres
# DATABASE_URL=postgres://usuario:senha@host:5432/banco
PGHOST=
PGUSER=
PGPASSWORD=
PGDATABASE=
PGPORT=5432
PGSSLMODE=require

# Opção de modelo OpenAI (se quiser usar GPT para metadados)
OPENAI_MODEL=gpt-4o-mini

# Chave de API OpenAI (opcional, use somente se quiser IA real)
OPENAI_API_KEY=
